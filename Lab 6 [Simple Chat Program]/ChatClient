import java.net.*;
import java.util.Scanner;
import java.io.*;

class ChatClient {

    public static void main(String[] args) {

        String ipAddress = ""; // IP address or domain name of Server 
        int port = 1728; // The port on which the server listens. [cite: 16]

        Socket connection = null; // For communication with the server.

        BufferedReader incoming = null; // Stream for receiving data from server. [cite: 17]
        PrintWriter outgoing = null; // Stream for sending data to server. 
        String messageOut; // A message to be sent to the server.
        String messageIn; // A message received from the server.

        Scanner userInput = new Scanner(System.in); // Standard input. [cite: 19]

        // 1. Get the IP address or domain name of the server from the user. 
        System.out.print("Enter computer name or IP address: ");
        ipAddress = userInput.nextLine(); // For testing, use 127.0.0.1 or localhost [cite: 22]
        
        // 2. Request connection to server on specified host and port [cite: 23]
        try {
            System.out.println("Connecting to " + ipAddress + " on port " + port);
            connection = new Socket(ipAddress, port); // Create new socket [cite: 23]
            
            // Set up input and output streams [cite: 24]
            outgoing = new PrintWriter(connection.getOutputStream(), true);
            incoming = new BufferedReader(new InputStreamReader(connection.getInputStream()));
            
            System.out.println("Connected.  Enter your first message.");
        }
        // If connection fails, print error message and end the program. [cite: 25]
        catch (Exception e) {
            System.out.println("ERROR: failed to connect to server. " + e.getMessage());
            userInput.close();
            return;
        }

        // 3. Exchange messages with the server. 
        try {
            System.out.println("NOTE: Enter 'quit' to end the program.\n");
            while (true) {
                // Step 5: Send a message to the server first [cite: 27]
                System.out.print("SEND:      ");
                messageOut = userInput.nextLine();
                outgoing.println(messageOut);

                if (messageOut.equalsIgnoreCase("quit")) {
                    System.out.println("Connection closed by client.");
                    break; // Exit loop to close connections [cite: 27]
                }
                
                // Check for errors while transmitting message.
                if (outgoing.checkError()) {
                    throw new IOException("Error while transmitting message.");
                }

                System.out.println("Waiting for response...");

                // Step 6: Listen for Server messages [cite: 28]
                messageIn = incoming.readLine();
                
                if (messageIn == null || messageIn.equalsIgnoreCase("quit")) {
                    System.out.println("RECEIVED: " + (messageIn == null ? "Server disconnected" : messageIn));
                    System.out.println("Connection closed by server.");
                    break; // Exit loop [cite: 28]
                }
                
                System.out.println("RECEIVED:  " + messageIn);
            }
        }
        // Handle message exchange failures [cite: 29]
        catch (Exception e) {
            System.out.println("ERROR: message failed to send/receive. " + e.getMessage());
        }
        // 4. Close the connection and end the program [cite: 27, 28]
        finally {
            System.out.println("End of program.");
            userInput.close();
            try {
                if (outgoing != null) outgoing.close();
                if (incoming != null) incoming.close();
                if (connection != null) connection.close();
            } catch (Exception e) {
                // Ignore errors that occur while closing 
            }
        }
    } 
}