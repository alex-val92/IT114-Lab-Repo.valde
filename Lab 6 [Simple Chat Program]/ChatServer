import java.net.*;
import java.util.Scanner;
import java.io.*;

public class ChatServer {
    public static void main(String[] args) {

        int port = 1728; // The port on which the server listens. [cite: 16]

        ServerSocket listener = null; // Listens for a connection request.
        Socket connection = null; // For communication with the client.

        BufferedReader incoming = null; // Stream for receiving data from client. [cite: 17]
        PrintWriter outgoing = null; // Stream for sending data to client. [cite: 18]
        String messageOut; // A message to be sent to the client.
        String messageIn; // A message received from the client.

        Scanner userInput = new Scanner(System.in); // Standard input. [cite: 19]

        // 1. Open ServerSocket to listen for connection requests on specified port.
        try {
            listener = new ServerSocket(port); // Create ServerSocket to listen on port [cite: 31]
            
            System.out.println("Listening on port " + listener.getLocalPort());

            // 2. Wait for a client connection request, and when one arrives, accept it. [cite: 32]
            connection = listener.accept(); 
            
            // Close the Server Socket to ensure only one client connects. 
            listener.close(); 

            // 3. Set up input and output streams for the new Socket created. [cite: 34]
            outgoing = new PrintWriter(connection.getOutputStream(), true);
            incoming = new BufferedReader(new InputStreamReader(connection.getInputStream()));
            
            System.out.println("Connected.  Waiting for the first message.");
        }
        // If failed to open/accept connection, print error message and end. [cite: 35]
        catch (Exception e) {
            System.out.println("ERROR: Could not establish connection. " + e.getMessage());
            userInput.close();
            return;
        }

        // 4. Exchange messages with the client. [cite: 36]
        try {
            while (true) {
                // Server waits to receive a message first. [cite: 37]
                System.out.println("Waiting for message...");

                messageIn = incoming.readLine();
                
                // If message received is "quit" or null, close and end. [cite: 37]
                if (messageIn == null || messageIn.equalsIgnoreCase("quit")) {
                    System.out.println("RECEIVED: " + (messageIn == null ? "Client disconnected" : messageIn));
                    System.out.println("Connection closed by client.");
                    break;
                }
                
                System.out.println("RECEIVED:  " + messageIn);

                // Have Server send a message back to the client. [cite: 38]
                System.out.print("SEND:      ");
                messageOut = userInput.nextLine();
                outgoing.println(messageOut);
                
                // If message sent is "quit", close and end. [cite: 38]
                if (messageOut.equalsIgnoreCase("quit")) {
                    System.out.println("Connection closed by server.");
                    break;
                }
                
                // Check for errors while transmitting message.
                if (outgoing.checkError()) {
                    throw new IOException("Error occurred while transmitting message.");
                }
            }
        }
        // If failed to exchange messages, print error message and end. [cite: 39]
        catch (Exception e) {
            System.out.println("ERROR: Message failed. " + e.getMessage());
        }
        // 5. Close the connection, whether there's an error or not. [cite: 10]
        finally {
            System.out.println("Closing connection...");
            userInput.close();
            try {
                if (outgoing != null) outgoing.close();
                if (incoming != null) incoming.close();
                if (connection != null) connection.close();
            } catch (Exception e) {
                // Ignore errors that occur while closing.
            }
        }
    } 
}