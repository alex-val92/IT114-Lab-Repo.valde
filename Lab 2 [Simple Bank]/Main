import java.util.Scanner;
public class Main {
    public static void main (String[] args){
        Scanner scan= new Scanner(System.in);
        System.out.println("Enter account holder name:");
        String name = scan.nextLine();
        System.out.println("Enter intial deposit to set account balance:");
        double initialDeposit = scan.nextDouble();
        System.out.println("What account type do you want to create?(Enter 1 or 2):");
        System.out.println("1. Checking Account");
        System.out.println("2. Savings Account");
        int accountType = scan.nextInt();
        BankAccount account;
        if (accountType == 1) {
            account = new CheckingAccount(name, initialDeposit);
        } else {
            account = new SavingsAccount(name, initialDeposit);
        }
        System.out.println("Welcome to the menu please select an option:");
        System.out.println("1. Deposit");
        System.out.println("2. Withdraw");
        System.out.println("3. View Balance");
        System.out.println("4. Exit");
        int choice = scan.nextInt();
        while (choice != 4) {
            switch (choice){
                case 1:
                    System.out.println("Enter deposit amount:");
                    double depositAmount = scan.nextDouble();
                    account.deposit(depositAmount);
                    break;
                case 2:
                    System.out.println("Enter withdrawl amount:");
                    double withdrawAmount = scan.nextDouble();
                    account.withdraw(withdrawAmount);
                    break;
                case 3:
                    System.out.println("The current balance is: " + account.getBalance());
                    break;
                case 4:
                    System.out.println("Goodbye");
                default:
                    System.out.println("Please select a number from the menu options");
            }
        }
        scan.close();
    }
}